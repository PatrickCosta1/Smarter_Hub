DATABASE_URL="postgresql://postgres:postgres@localhost:5432/smarter_hub?schema=public"
PORT=4000
FRONTEND_URL="http://localhost:5173,https://smarterhub.netlify.app"
JWT_SECRET="smarter-hub-dev-secret"

# Login local (utilizador/password) para testes de desenvolvimento.
# Em produção, manter false para Microsoft-only.
AUTH_ENABLE_LOCAL_LOGIN="false"

# Firebase Admin (usar uma das duas opções)
# Opção A: JSON completo da service account numa única variável
# FIREBASE_SERVICE_ACCOUNT_JSON='{"project_id":"...","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"}'

# Opção B: campos separados
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# Microsoft/Firebase auth
# Ativa provisão automática no primeiro login Microsoft.
AUTH_MICROSOFT_AUTO_PROVISION="false"
# Domínios autorizados (se vazio, aceita qualquer domínio).
MICROSOFT_ALLOWED_EMAIL_DOMAINS=""
# Papel padrão para utilizadores auto-provisionados.
AUTH_MICROSOFT_DEFAULT_ROLE="COLABORADOR"
# País laboral padrão para perfil criado automaticamente: PT ou BR.
AUTH_MICROSOFT_DEFAULT_WORK_COUNTRY="PT"
# Password inicial opcional para utilizadores provisionados automaticamente.
# Se vazio, será gerada password aleatória (não previsível).
AUTH_PROVISION_INITIAL_PASSWORD=""

# Azure App Registration para envio de email (Microsoft Graph)
# Tenant ID do Microsoft Entra ID (Directory ID)
AZURE_MAIL_TENANT_ID="386f9254-680d-487c-ac65-d01d3e064647"
# Application (client) ID da App Registration
AZURE_MAIL_CLIENT_ID="1ed04e88-370b-43af-8b5a-e69ba203dd33"
# Client secret da App Registration
AZURE_MAIL_CLIENT_SECRET=""
# UPN/email da mailbox emissora (ex.: no-reply@empresa.com)
AZURE_MAIL_SENDER_USER="t.people@tlantic.com"
