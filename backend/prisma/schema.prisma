generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  COLABORADOR
  MANAGER
  COORDENADOR
  ADMIN
  CONVIDADO
}

enum WorkCountry {
  PT
  BR
}

enum VacationRequestType {
  VACATION
  ABSENCE_MEDICAL
  ABSENCE_TRAINING
}

enum VacationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model Team {
  id            String      @id @default(cuid())
  name          String      @unique
  country       WorkCountry @default(PT)
  managerId     String?     @unique
  coordinatorId String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  members       User[]      @relation("TeamMembers")
  manager       User?       @relation("TeamManager", fields: [managerId], references: [id], onDelete: SetNull)
  coordinator   User?       @relation("TeamCoordinator", fields: [coordinatorId], references: [id], onDelete: SetNull)
}

model User {
  id            String         @id @default(cuid())
  username      String         @unique
  email         String         @unique
  passwordHash  String
  role          Role           @default(COLABORADOR)
  teamId        String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  team          Team?          @relation("TeamMembers", fields: [teamId], references: [id], onDelete: SetNull)
  managedTeam   Team?          @relation("TeamManager")
  coordinatedTeams Team[]      @relation("TeamCoordinator")
  profile       Profile?
  notifications Notification[]
  trainings     Training[]       @relation("TrainingUser")
  assignedTrainings Training[]   @relation("TrainingAssigner")
  vacations     Vacation[]       @relation("VacationUser")
  reviewedVacations Vacation[]    @relation("VacationReviewer")
  profileChangeRequests ProfileChangeRequest[] @relation("ProfileChangeRequestUser")
  reviewedProfileChangeRequests ProfileChangeRequest[] @relation("ProfileChangeRequestReviewer")
}

model Profile {
  id                             String   @id @default(cuid())
  userId                         String   @unique
  primeiroNome                   String   @default("")
  apelido                        String   @default("")
  nomeAbreviado                  String   @default("")
  dataNascimento                 String   @default("")
  genero                         String   @default("")
  estadoCivil                    String   @default("")
  habilitacoesLiterarias         String   @default("")
  curso                          String   @default("")
  faculdade                      String   @default("")
  emailPessoal                   String   @default("")
  telemovel                      String   @default("")
  moradaFiscal                   String   @default("")
  endereco                       String   @default("")
  localidade                     String   @default("")
  codigoPostal                   String   @default("")
  matriculaCarro                 String   @default("")
  cartaoCidadao                  String   @default("")
  nif                            String   @default("")
  niss                           String   @default("")
  iban                           String   @default("")
  situacaoIrs                    String   @default("")
  numeroDependentes              String   @default("")
  irsJovem                       String   @default("")
  anoPrimeiroDesconto            String   @default("")
  numeroCartaoContinente         String   @default("")
  voucherNosData                 String   @default("")
  comprovativoMoradaFiscal       String   @default("")
  comprovativoCartaoCidadao      String   @default("")
  comprovativoIban               String   @default("")
  comprovativoCartaoContinente   String   @default("")
  contactoEmergenciaNome         String   @default("")
  contactoEmergenciaParentesco   String   @default("")
  contactoEmergenciaNumero       String   @default("")
  cargo                          String   @default("")
  funcao                         String   @default("")
  dataInicioContrato             String   @default("")
  dataFimContrato                String   @default("")
  remuneracao                    String   @default("")
  tipoContrato                   String   @default("")
  regimeHorario                  String   @default("")
  workCountry                    WorkCountry @default(PT)
  unjustifiedAbsences            Int      @default(0)
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt
  user                           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workCountry])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Training {
  id            String   @id @default(cuid())
  userId        String
  nome          String
  link          String   @default("")
  horas         Float
  duracao       String   @default("")
  entidade      String   @default("")
  dataConclusao String   @default("")
  status        String   @default("CONCLUIDA")
  assignedByUserId String?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation("TrainingUser", fields: [userId], references: [id], onDelete: Cascade)
  assignedBy    User?    @relation("TrainingAssigner", fields: [assignedByUserId], references: [id], onDelete: SetNull)
}

model Vacation {
  id           String   @id @default(cuid())
  userId       String
  dataInicio   String
  dataFim      String
  observacoes  String   @default("")
  requestType  VacationRequestType @default(VACATION)
  attachmentLink String @default("")
  status       VacationStatus @default(PENDING)
  reviewedById String?
  reviewedAt   DateTime?
  reviewReason String   @default("")
  approvedByRole String @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation("VacationUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy   User?    @relation("VacationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([userId, status])
}

model ProfileChangeRequest {
  id            String   @id @default(cuid())
  userId        String
  requestedData Json
  changesSummary String
  status        String   @default("PENDING")
  reviewedById  String?
  reviewedAt    DateTime?
  reviewReason  String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation("ProfileChangeRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy    User?    @relation("ProfileChangeRequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
}
