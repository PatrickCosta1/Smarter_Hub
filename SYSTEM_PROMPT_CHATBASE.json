  "workflows": {
    "vacation_approval": {
      "trigger": "POST /vacations",
      "requiresPermission": "request_vacation",
      "initialStatus": "PENDING",
      "model": "Vacation { id, userId, status, contextTeamId, ... }",
      "approvals": "VacationApproval[] { vacationId, approverId, approvalLevel, status }",
      "steps": [
        {
          "level": 1,
          "description": "Team leader or activity manager",
          "permissionRequired": "approve_vacation OR reject_vacation",
          "restrictedBy": "contextTeamId (auto-linked to user's team)",
          "statusAfter": "WAITING (next level) or APPROVED or REJECTED"
        },
        {
          "level": 2,
          "description": "HR/Coordinator second approval",
          "permissionRequired": "approve_vacation",
          "prerequisite": "Level 1 APPROVED",
          "statusAfter": "APPROVED or REJECTED"
        }
      ],
      "validations": [
        "enforceVacationBusinessDays (no weekends/holidays)",
        "validateVacationCountryPolicy (PT vs BR)"
      ],
      "countryPolicies": {
        "PT": {
          "mandatory": "10 consecutive business days per year",
          "fractionated": "Allowed with limitations",
          "weekends": "Not counted"
        },
        "BR": {
          "minDaysPerPeriod": "5 running days",
          "maxPeriods": 3,
          "mandatoryBlock": "1 period >= 14 days if 3 periods",
          "fractionatedAllowed": false,
          "weekends": "Counted as running days"
        }
      },
      "specialCases": [
        "t.people cannot submit vacations",
        "sara cannot submit vacations"
      ]
    },
    "profile_change_approval": {
      "trigger": "POST /profile/request",
      "requiresPermission": "request_profile_change",
      "initialStatus": "PENDING",
      "model": "ProfileChangeRequest { id, userId, status, requestedData: JSON, changesSummary, ... }",
      "steps": [
        {
          "description": "Submit request",
          "actor": "Employee",
          "action": "Submit JSON with profile field changes",
          "statusAfter": "PENDING"
        },
        {
          "description": "Review and approve",
          "actor": "HR/Coordinator/People",
          "permissionRequired": "approve_profile_change",
          "actions": [
            {
              "action": "APPROVE",
              "effect": "Apply requestedData fields to Profile, update Profile.updatedAt",
              "notification": "Email + in-app: 'Profile updated successfully'"
            },
            {
              "action": "REJECT",
              "effect": "Retain requestedData, mark REJECTED, send reason",
              "notification": "Email + in-app with rejection reason"
            }
          ]
        }
      ],
      "fields": [
        "primeiroNome", "apelido", "nomeAbreviado",
        "dataNascimento", "genero", "estadoCivil",
        "habilitacoesLiterarias", "curso", "faculdade",
        "emailPessoal", "telemovel",
        "moradaFiscal", "endereco", "localidade", "codigoPostal",
        "matriculaCarro", "cartaoCidadao",
        "nif", "niss", "iban",
        "situacaoIrs", "numeroDependentes", "irsJovem", "anoPrimeiroDesconto",
        "numeroCartaoContinente", "voucherNosData",
        "comprovativoMoradaFiscal", "comprovativoCartaoCidadao", "comprovativoIban", "comprovativoCartaoContinente",
        "contactoEmergenciaNome", "contactoEmergenciaParentesco", "contactoEmergenciaNumero",
        "cargo", "funcao", "dataInicioContrato", "dataFimContrato",
        "remuneracao", "tipoContrato", "regimeHorario",
        "workCountry"
      ]
    },
    "permission_assignment": {
      "trigger": "POST /users/:id/permissions",
      "requiresPermission": "manage_permissions",
      "prequisites": [
        "actor.manage_permissions",
        "actor.isRootAccess OR actor.hasAccessTotal"
      ],
      "operations": [
        {
          "operation": "GRANT",
          "payload": {
            "permissionCode": "string",
            "isEnabled": true,
            "restrictedToTeams": "optional array",
            "restrictedToCountries": "optional [PT, BR]",
            "restrictedToLevels": "optional array",
            "customRestrictions": "optional JSON",
            "notes": "human reason",
            "reason": "audit log reason"
          },
          "effects": [
            "Create/update UserPermission entry",
            "Log PermissionGrant event with action=GRANT",
            "If enabledPermissions == totalPermissions → auto-set hasAccessTotal=true"
          ]
        },
        {
          "operation": "REVOKE",
          "prequisites": [
            "actor == grantedById (who granted can revoke) OR actor.isRootAccess"
          ],
          "payload": {
            "reason": "audit log reason"
          },
          "effects": [
            "Soft-delete: UserPermission.isEnabled = false",
            "Log PermissionGrant event with action=REVOKE",
            "If enabledPermissions < totalPermissions → auto-set hasAccessTotal=false"
          ]
        }
      ],
      "restrictionLevels": {
        "global": "No restrictions = access to all instances",
        "team": "restrictedToTeams = limited to specific teams",
        "country": "restrictedToCountries = limited to PT or BR",
        "hierarchyLevel": "restrictedToLevels = limited to specific hierarchy levels"
      },
      "auditLog": "All events in PermissionGrant with timestamps and reasons"
    }
  },
