{
  "name": "smarter-hub-react",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "perf:budget": "node scripts/check-performance-budget.mjs",
    "quality:frontend": "npm run build && npm run perf:budget",
    "preview": "vite preview",
    "e2e": "node scripts/run-e2e-with-cleanup.mjs",
    "e2e:raw": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:cleanup": "node scripts/cleanup-e2e-residuals.mjs && npm --prefix backend run cleanup:audit"
  },
  "dependencies": {
    "@sentry/react": "^10.53.0",
    "exceljs": "^4.4.0",
    "firebase": "^12.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
